# PAI AeroNews Environment Variables

# Optional: Anthropic API key for AI-generated takeaways via Claude
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Buttondown API key for email subscriptions (Phase 2)
# Get yours at: https://buttondown.email/
BUTTONDOWN_API_KEY=your_buttondown_key_here

# Optional: Teams webhook URL for Analyst Mode SMS digest (Phase 2)
ANALYST_TEAMS_WEBHOOK_URL=your_analyst_teams_webhook_url_here
